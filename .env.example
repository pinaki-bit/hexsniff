# HexSniff Environment Configuration
# Copy this file to .env and configure your variables before starting.

# ---------------------------------------------------------
# SECURITY CONFIGURATION
# ---------------------------------------------------------
# Gemini API Key for the AI Analyst component.
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY="your_api_key_here"

# ---------------------------------------------------------
# NETWORK CONFIGURATION
# ---------------------------------------------------------
# The port the FastAPI backend runs on (Default: 8000)
BACKEND_PORT=8000

# The port the Vite React frontend runs on (Default: 5173)
FRONTEND_PORT=5173

# ---------------------------------------------------------
# THREAT FEED CONFIGURATION
# ---------------------------------------------------------
# Optional: Set update intervals for threat intel (in hours)
# THREAT_FEED_SYNC_INTERVAL=24

# ---------------------------------------------------------
# DEBUG & LOGGING
# ---------------------------------------------------------
# Enable detailed logging for the detection engine
DEBUG=False
